{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":dependencyDashboard",
    ":automergeMinor",
    "schedule:weekly"
  ],
  "timezone": "Asia/Shanghai",
  "semanticCommitType": "chore",
  "semanticCommitScope": "deps",
  "commitMessageTopic": "{{depName}}",
  "commitMessageExtra": "至 {{newVersion}}",
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "packageRules": [
    {
      "groupName": "UnoCSS 全家桶",
      "matchPackagePatterns": ["^@unocss/", "^unocss$"]
    },
    {
      "groupName": "Vueuse 全家桶",
      "matchPackagePatterns": ["^@vueuse/"]
    },
    {
      "groupName": "Rolldown 全家桶",
      "matchPackagePatterns": ["^@rolldown/", "^rolldown$"]
    },
    {
      "matchUpdateTypes": ["patch"],
      "matchCurrentVersion": "!/^0/",
      "automerge": true,
      "automergeType": "pr",
      "description": "稳定包 patch 版本自动合并"
    },
    {
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "pr",
      "description": "devDependencies 的 minor/patch 自动合并"
    },
    {
      "matchUpdateTypes": ["major"],
      "addLabels": ["major"],
      "automerge": false,
      "description": "major 版本需要人工审阅"
    },
    {
      "matchPackageNames": ["typescript"],
      "automerge": false,
      "description": "TypeScript 受工具链限制需人工确认"
    },
    {
      "matchPackageNames": ["vite-plus"],
      "automerge": false,
      "description": "vite-plus 是核心构建工具需人工确认"
    },
    {
      "matchDepTypes": ["engines"],
      "enabled": false,
      "description": "不自动升级 Node.js engine 约束"
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"],
    "schedule": ["at any time"]
  }
}
