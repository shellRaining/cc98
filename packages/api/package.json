{
  "name": "@cc98/api",
  "version": "0.1.0-alpha.0",
  "private": true,
  "description": "CC98 API 的 Zod 契约、OpenAPI 文档与接口验证工具",
  "homepage": "https://github.com/shellRaining/cc98/tree/main/packages/api#readme",
  "bugs": {
    "url": "https://github.com/shellRaining/cc98/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shellRaining/cc98.git",
    "directory": "packages/api"
  },
  "files": [
    "dist",
    "generated",
    "CHANGELOG.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./openapi.json": "./generated/openapi.json",
    "./openapi.yaml": "./generated/openapi.yaml",
    "./openid.openapi.json": "./generated/openid.openapi.json",
    "./openid.openapi.yaml": "./generated/openid.openapi.yaml",
    "./catalog": "./generated/endpoint-catalog.json",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vp pack",
    "generate": "node scripts/generate.mjs && vp fmt generated --write",
    "probe:anonymous": "node scripts/probe.mjs",
    "probe:authenticated": "node --env-file-if-exists=../../.cc98-credentials.local scripts/probe.mjs --authenticated --auth-blocked",
    "docs:build": "node scripts/build-docs.mjs",
    "docs:check": "node scripts/build-docs.mjs --check",
    "pack:check": "node scripts/check-package.mjs",
    "test": "node scripts/check-generated.mjs && node scripts/build-docs.mjs --check && vp test",
    "check": "vp check",
    "prepack": "node scripts/check-generated.mjs && vp pack"
  },
  "dependencies": {
    "zod": "catalog:",
    "zod-openapi": "catalog:"
  },
  "devDependencies": {
    "@redocly/cli": "catalog:",
    "@types/node": "catalog:",
    "apifox-cli": "2.2.7",
    "typescript": "catalog:",
    "vite-plus": "catalog:",
    "yaml": "catalog:"
  },
  "engines": {
    "node": ">=22.18.0"
  }
}
